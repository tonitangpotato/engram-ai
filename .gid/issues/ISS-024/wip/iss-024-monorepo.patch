+        let mut cache = crate::temporal_dim::DimParseCache::new(16);
+
+        let score = Memory::temporal_score(&record, &Some(query_range), now, &mut cache);
+        // Dim range fully contained in query range → dim_score = 1.0
+        // Insertion score = 0.0 (created_at is 90 days outside)
+        // max(0.0, 1.0) = 1.0
