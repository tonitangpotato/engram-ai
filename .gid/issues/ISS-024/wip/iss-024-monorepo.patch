+    /// Convert the record's stored `TemporalMark` into a `TimeRange` and
+    /// score its overlap against the query's time range.
+    ///
+    /// Returns `None` if:
+    /// - the record has no temporal dimension, OR
+    /// - the `Vague` phrase is unparseable (cache returns `None`).
+    ///
+    /// Callers treat `None` as "skip dim channel; fall back to insertion score".
+    /// Design ref: `.gid/issues/ISS-024-.../design.md` §5.3.
+    fn dimension_time_score(
+        record: &MemoryRecord,
+        query_range: &crate::query_classifier::TimeRange,
+        dim_parser: &mut crate::temporal_dim::DimParseCache,
+    ) -> Option<f64> {
+        use crate::dimension_access::DimensionView;
+        use crate::dimensions::TemporalMark;
+        use crate::query_classifier::TimeRange;
+        use chrono::{Duration, NaiveTime};
+
+        let view = DimensionView::from_record(record);
+        let dim_range: TimeRange = match view.temporal()? {
+            TemporalMark::Exact(dt) => TimeRange {
+                start: *dt,
+                end: *dt,
+            },
+            TemporalMark::Range { start, end } => {
+                // NaiveDate endpoints (inclusive) → UTC range covering
+                // [start 00:00, end+1 00:00). Range is thus day-granular, not
+                // DateTime-granular. NaiveTime::MIN is const and infallible
+                // (no `?` needed in this Option-returning context, but also no
+                // `unwrap` footgun as with and_hms_opt).
+                let s = start.and_time(NaiveTime::MIN).and_utc();
+                let e = end.and_time(NaiveTime::MIN).and_utc() + Duration::days(1);
+                TimeRange { start: s, end: e }
+            }
+            TemporalMark::Day(date) => {
+                // Midnight-to-midnight UTC range for the stored calendar day.
+                let start = date.and_time(NaiveTime::MIN).and_utc();
+                let end = start + Duration::days(1);
+                TimeRange { start, end }
+            }
+            TemporalMark::Vague(phrase) => {
+                // Only variant that hits two_timer. Cache collapses repeated
+                // phrases to O(1) after first parse.
+                dim_parser.get_or_parse(phrase, record.created_at)?
+            }
+        };
+
+        Some(Self::range_overlap_score(query_range, &dim_range))
+    }
+
+    /// Overlap score between two time ranges in `[0.0, 1.0]`.
+    ///
+    /// Returns:
+    /// - `0.0` if the ranges are disjoint
+    /// - `1.0` if the dim range is entirely inside the query range (perfect hit)
+    /// - `overlap_seconds / dim_duration` otherwise — biased toward "how much
+    ///   of the dim's claim falls inside what the query asked for", since the
+    ///   query range is the reference and we're rating the candidate.
+    ///
+    /// Point-in-time dim ranges (`Exact`: start==end) score 1.0 iff the point
+    /// is inside the query range, 0.0 otherwise.
+    fn range_overlap_score(
+        query_range: &crate::query_classifier::TimeRange,
+        dim_range: &crate::query_classifier::TimeRange,
+    ) -> f64 {
+        let overlap_start = query_range.start.max(dim_range.start);
+        let overlap_end = query_range.end.min(dim_range.end);
+        if overlap_end < overlap_start {
+            return 0.0;
+        }
+        let overlap_secs = (overlap_end - overlap_start).num_seconds() as f64;
+        let dim_secs = (dim_range.end - dim_range.start).num_seconds() as f64;
+
+        if dim_secs <= 0.0 {
+            // Point-in-time dim: contained iff we got here (overlap_end >= overlap_start).
+            1.0
+        } else {
+            (overlap_secs / dim_secs).clamp(0.0, 1.0)
+        }
+    }
     
